<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <handlers>
      <!--
        Route ALL requests through Flask/wfastcgi.
        Flask will serve index.html for GET / and handle POST /contact.

        IMPORTANT — Python path:
          Log in to your SmarterASP.NET control panel, go to
          "Python" or "App Settings" to find the exact Python path
          for your account. Replace the two paths below if they differ.
          Common SmarterASP.NET paths:
            C:\Python39\python.exe
            C:\Python310\python.exe
      -->
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\Python39\python.exe|C:\Python39\Scripts\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <defaultDocument>
      <files>
        <!-- Serve index.html when someone visits the root URL -->
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

  </system.webServer>

  <appSettings>
    <!-- Tells wfastcgi which Flask app object to use -->
    <add key="WSGI_HANDLER" value="contact_server.app" />
    <!-- Root folder of your site on the server -->
    <add key="PYTHONPATH" value="D:\home\intare-001\www\site1" />
  </appSettings>
</configuration>
